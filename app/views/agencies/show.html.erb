<%= turbo_stream_from @agency %>   <%# subscribe to this agency's stream %>

<%= render @agency %>
<div id="agency_<%= @agency.id %>_total">
  <%= render "agencies/total", agency: @agency %>
</div>

<h2>Advisors</h2>
<ul>
  <% @agency.advisors.each do |advisor| %>
    <li><%= link_to advisor.name, advisor %> — <%= advisor.email %></li>
  <% end %>
</ul>
<%= link_to "Add advisor", new_advisor_path, class: "btn" %>

<h2>Bookings</h2>
<div id="bookings">                <%# broadcast append/replace/remove target %>
  <%= render @agency.bookings %>
</div>
<div class="actions">
  <%= link_to "Edit this agency", edit_agency_path(@agency) %>
  <%= link_to "Back to agencies", agencies_path %>
  <%= button_to "Destroy this agency", @agency, method: :delete, class: "btn btn--danger" %>
</div>
