<%= form_with(model: advisor) do |form| %>
  <% if advisor.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(advisor.errors.count, "error") %> prohibited this advisor from being saved:</h2>

      <ul>
        <% advisor.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :email, style: "display: block" %>
    <%= form.text_field :email %>
  </div>

<div>
  <%= form.label :agency_id, "Agency" %>
  <%= form.collection_select :agency_id, Agency.order(:name), :id, :name,
        { prompt: "Select an agency" } %>
</div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
