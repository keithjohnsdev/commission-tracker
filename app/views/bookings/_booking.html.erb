<%= turbo_frame_tag dom_id(booking) do %>
<div class="booking">
  <div>
    <strong>Advisor:</strong>
    <%= booking.advisor_id %>
  </div>

  <div>
    <strong>Supplier name:</strong>
    <%= booking.supplier_name %>
  </div>

  <div>
    <strong>Trip name:</strong>
    <%= booking.trip_name %>
  </div>

  <div>
    <strong>Total amount:</strong>
    <%= booking.total_amount %>
  </div>

  <div>
    <strong>Commission rate:</strong>
    <%= booking.commission_rate %>
  </div>

  <div>
    <strong>Travel date:</strong>
    <%= booking.travel_date %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= booking.status %>
  </div>

  <div>
    <strong>Commission received:</strong>
    <%= booking.commission_received %>
  </div>

  <%= button_to (booking.commission_received? ? "✓ Received" : "Mark received"),
    toggle_received_booking_path(booking),
    method: :patch,
    form: { data: { turbo_frame: "_top" } },
    class: booking.commission_received? ? "received" : "pending" %>
  <%= link_to "Edit", edit_booking_path(booking) %>
  <%= link_to "Show", booking, data: { turbo_frame: "_top" } %>
</div>
<% end %>
